# ──────────────────────────────────────────────
#  Matrimony AI Agent — Environment Variables
# ──────────────────────────────────────────────

# Flask
FLASK_ENV=development
FLASK_SECRET_KEY=change-this-to-a-long-random-string-in-production
PORT=5000

# Google OAuth 2.0
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite:///./data/matrimony.db
# DATABASE_URL=postgresql://user:password@localhost:5432/matrimony_db

# Groq AI
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# File Upload
MAX_UPLOAD_SIZE_MB=50
UPLOAD_FOLDER=./input
OUTPUT_FOLDER=./output
ALLOWED_EXTENSIONS=pdf,docx,doc,txt,jpg,jpeg,png

# File Storage (local by default; set to "s3" for production)
STORAGE_BACKEND=local
# S3 settings (only needed when STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1

# AI Processing
MAX_CHARS_PER_PAGE=5000
REQUEST_DELAY=2.0
DB_TABLE=register

# Logging
LOG_DIR=./logs
LOG_LEVEL=INFO

# Security
CSRF_TIME_LIMIT=3600
SESSION_COOKIE_SECURE=false   # Set true in production (HTTPS)
SESSION_COOKIE_HTTPONLY=true
